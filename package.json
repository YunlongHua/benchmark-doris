{
  "name": "doris-benchmark-dev",
  "version": "1.0.0",
  "description": "Doris Benchmark Application",
  "author": "Doris Team",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm run electron:dev\"",
    "electron:dev": "npm run build:main && wait-on http://localhost:5173 && env -u ELECTRON_RUN_AS_NODE electron .",
    "build:main": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --outdir=dist-electron --external:electron --external:fs --external:path --external:child_process --external:fs/promises",
    "build": "npm run build:main && vite build",
    "package": "npm run build && electron-builder --win --dir",
    "preview": "vite preview"
  },
  "dependencies": {
    "antd": "^5.0.0",
    "echarts": "^5.0.0",
    "js-yaml": "^4.1.0",
    "mysql2": "^3.22.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sql-formatter": "^15.7.3",
    "ssh2": "^1.17.0",
    "zustand": "^4.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "wait-on": "^7.2.0"
  }
}
